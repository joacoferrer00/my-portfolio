# ── Fabric / Delta Table ─────────────────────────────────────────────────────
# Name of the Delta table written by the Dataflow Gen2
NPS_TABLE_NAME=cx_nps_rolling_5w

# Lakehouse folder where CSV files are written before upload
LOCAL_EXPORT_FOLDER=/lakehouse/default/Files/dumps

# ── Azure Active Directory App Registration ──────────────────────────────────
# Found in Azure Portal → Azure Active Directory → App Registrations → your app
AAD_TENANT_ID=your-aad-tenant-id
AAD_CLIENT_ID=your-app-client-id
AAD_CLIENT_SECRET=your-app-client-secret

# ── SharePoint / Microsoft Graph ─────────────────────────────────────────────
# Format: yourtenant.sharepoint.com:/sites/your-site-name
SPO_SITE_PATH=yourtenant.sharepoint.com:/sites/your-site-name

# Target folder path within the SharePoint drive
SPO_FOLDER_PATH=Reports/NPS/Rolling5W

# Obtain SITE_ID and DRIVE_ID via Graph Explorer:
#   GET https://graph.microsoft.com/v1.0/sites/{SPO_SITE_PATH}
#   GET https://graph.microsoft.com/v1.0/sites/{site-id}/drives
SPO_SITE_ID=yourtenant.sharepoint.com,<site-guid>,<web-guid>
SPO_DRIVE_ID=your-drive-id
